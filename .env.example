# Copia este archivo a .env.local y rellena con los valores reales del proyecto Firebase.
# .env.local NO se sube al repo (ver .gitignore).
# La apiKey web de Firebase es pública por diseño; la seguridad real depende
# de Firebase Auth + las reglas de RTDB (Fase 2).

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_DATABASE_URL=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Email del único admin que puede editar (debe coincidir con la regla RTDB)
VITE_ADMIN_EMAIL=
